{
  "info": {
    "name": "TicketFull API",
    "description": "Coleção completa da API de gerenciamento de eventos e ingressos com autenticação JWT.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8081",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "eventId",
      "value": "",
      "type": "string"
    },
    {
      "key": "ticketBatchId",
      "value": "",
      "type": "string"
    },
    {
      "key": "orderId",
      "value": "",
      "type": "string"
    },
    {
      "key": "codeHash",
      "value": "",
      "type": "string"
    },
    {
      "key": "ticketId",
      "value": "",
      "type": "string"
    },
    {
      "key": "paymentIntentId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Autenticação",
      "item": [
        {
          "name": "Registrar usuário (CUSTOMER)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"cliente@email.com\",\n  \"password\": \"senha123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            },
            "description": "Auto-registro público: cria sempre um usuário CUSTOMER (o papel não é aceito do cliente)."
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.accessToken) {",
                  "    pm.collectionVariables.set('accessToken', json.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"organizador@email.com\",\n  \"password\": \"senha123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Autentica o usuário e salva o accessToken automaticamente na variável da coleção."
          },
          "response": []
        },
        {
          "name": "Renovar token (Refresh)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.accessToken) {",
                  "    pm.collectionVariables.set('accessToken', json.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "refresh"]
            },
            "description": "Renova o access token usando o refreshToken salvo em cookie HttpOnly."
          },
          "response": []
        },
        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.collectionVariables.set('accessToken', '');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "logout"]
            },
            "description": "Encerra a sessão e invalida o refresh token. Limpa o accessToken da coleção."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Administração",
      "item": [
        {
          "name": "Criar usuário com papel (ADMIN)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"organizador@email.com\",\n  \"password\": \"senha123\",\n  \"role\": \"ORGANIZER\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/users",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "users"]
            },
            "description": "Provisiona um usuário com papel definido (ORGANIZER/ADMIN). Requer um token de ADMIN."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Eventos",
      "item": [
        {
          "name": "Criar evento",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.id) {",
                  "    pm.collectionVariables.set('eventId', json.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Show de Rock 2026\",\n  \"description\": \"O maior show de rock do ano!\",\n  \"eventDate\": \"2026-12-31T21:00:00Z\",\n  \"location\": \"Estádio Nacional, Brasília\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/events",
              "host": ["{{baseUrl}}"],
              "path": ["events"]
            },
            "description": "Cria um novo evento. Requer perfil ORGANIZER. Salva o eventId automaticamente."
          },
          "response": []
        },
        {
          "name": "Listar eventos",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/events",
              "host": ["{{baseUrl}}"],
              "path": ["events"]
            },
            "description": "Retorna todos os eventos cadastrados."
          },
          "response": []
        },
        {
          "name": "Buscar evento por ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/events/{{eventId}}",
              "host": ["{{baseUrl}}"],
              "path": ["events", "{{eventId}}"]
            },
            "description": "Busca um evento específico pelo seu UUID."
          },
          "response": []
        },
        {
          "name": "Atualizar evento (organizador)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Show de Rock 2026 (atualizado)\",\n  \"description\": \"Nova descrição\",\n  \"eventDate\": \"2026-12-31T21:00:00Z\",\n  \"location\": \"Estádio Nacional, Brasília\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/events/{{eventId}}",
              "host": ["{{baseUrl}}"],
              "path": ["events", "{{eventId}}"]
            },
            "description": "Atualiza os dados de um evento do próprio organizador (não permitido se cancelado)."
          },
          "response": []
        },
        {
          "name": "Publicar evento (organizador)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
            "url": {
              "raw": "{{baseUrl}}/events/{{eventId}}/publish",
              "host": ["{{baseUrl}}"],
              "path": ["events", "{{eventId}}", "publish"]
            },
            "description": "Publica um evento DRAFT (DRAFT -> PUBLISHED). Só eventos publicados aparecem na busca e aceitam vendas."
          },
          "response": []
        },
        {
          "name": "Cancelar evento (organizador)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ],
            "url": {
              "raw": "{{baseUrl}}/events/{{eventId}}/cancel",
              "host": ["{{baseUrl}}"],
              "path": ["events", "{{eventId}}", "cancel"]
            },
            "description": "Cancela um evento do próprio organizador, encerrando novas vendas."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Lotes de Ingressos",
      "item": [
        {
          "name": "Adicionar lote ao evento",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.id) {",
                  "    pm.collectionVariables.set('ticketBatchId', json.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Pista\",\n  \"price\": 120.00,\n  \"totalCapacity\": 500,\n  \"salesStartAt\": null,\n  \"salesEndAt\": null\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/events/{{eventId}}/ticket-batches",
              "host": ["{{baseUrl}}"],
              "path": ["events", "{{eventId}}", "ticket-batches"]
            },
            "description": "Adiciona um lote de ingressos a um evento. Requer perfil ORGANIZER e ser o dono do evento. Salva o ticketBatchId automaticamente."
          },
          "response": []
        },
        {
          "name": "Listar lotes do evento",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/events/{{eventId}}/ticket-batches",
              "host": ["{{baseUrl}}"],
              "path": ["events", "{{eventId}}", "ticket-batches"]
            },
            "description": "Lista todos os lotes de ingressos de um evento."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Pedidos",
      "item": [
        {
          "name": "Comprar ingressos",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.id) {",
                  "    pm.collectionVariables.set('orderId', json.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ticketBatchId\": \"{{ticketBatchId}}\",\n  \"quantity\": 2\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/orders",
              "host": ["{{baseUrl}}"],
              "path": ["orders"]
            },
            "description": "Cria um pedido de compra de ingressos. Requer perfil CUSTOMER. Salva o orderId automaticamente."
          },
          "response": []
        },
        {
          "name": "Listar meus pedidos",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/orders",
              "host": ["{{baseUrl}}"],
              "path": ["orders"]
            },
            "description": "Lista todos os pedidos do cliente autenticado."
          },
          "response": []
        },
        {
          "name": "Buscar pedido por ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/orders/{{orderId}}",
              "host": ["{{baseUrl}}"],
              "path": ["orders", "{{orderId}}"]
            },
            "description": "Busca um pedido específico do cliente autenticado pelo UUID."
          },
          "response": []
        },
        {
          "name": "Iniciar checkout do pedido",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  pm.collectionVariables.set('paymentIntentId', pm.response.json().paymentIntentId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/orders/{{orderId}}/checkout",
              "host": ["{{baseUrl}}"],
              "path": ["orders", "{{orderId}}", "checkout"]
            },
            "description": "Inicia o pagamento criando um PaymentIntent no gateway e retorna os dados de checkout (paymentIntentId, clientSecret). O pedido permanece PENDING até a confirmação pelo webhook. O script de teste salva o paymentIntentId em {{paymentIntentId}}."
          },
          "response": []
        },
        {
          "name": "Cancelar pedido",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/orders/{{orderId}}/cancel",
              "host": ["{{baseUrl}}"],
              "path": ["orders", "{{orderId}}", "cancel"]
            },
            "description": "Cancela um pedido PENDING (PENDING → CANCELLED), devolvendo os assentos ao lote. Requer ser o dono do pedido."
          },
          "response": []
        },
        {
          "name": "Estornar pedido pago",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/orders/{{orderId}}/refund",
              "host": ["{{baseUrl}}"],
              "path": ["orders", "{{orderId}}", "refund"]
            },
            "description": "Estorna um pedido já pago (PAID → REFUNDED), solicitando o reembolso ao gateway e devolvendo os assentos. Requer ser o dono do pedido."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Webhooks",
      "item": [
        {
          "name": "Confirmar pagamento (webhook do gateway)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"payment_intent.succeeded\",\n  \"paymentIntentId\": \"{{paymentIntentId}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/webhooks/payments",
              "host": ["{{baseUrl}}"],
              "path": ["webhooks", "payments"]
            },
            "description": "Simula o callback do gateway de pagamento confirmando o pedido (PENDING → PAID). Endpoint público e idempotente. Use após 'Iniciar checkout do pedido' (que preenche {{paymentIntentId}})."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Ingressos",
      "item": [
        {
          "name": "Validar ingresso (check-in)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/tickets/{{codeHash}}/validate",
              "host": ["{{baseUrl}}"],
              "path": ["tickets", "{{codeHash}}", "validate"]
            },
            "description": "Valida um ingresso no check-in do evento (marca como USED). Requer perfil ORGANIZER e ser o dono do evento. Defina a variável {{codeHash}} com o hash do ingresso."
          },
          "response": []
        },
        {
          "name": "Transferir ingresso (detentor atual)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"targetEmail\": \"outro-cliente@email.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tickets/{{ticketId}}/transfer",
              "host": ["{{baseUrl}}"],
              "path": ["tickets", "{{ticketId}}", "transfer"]
            },
            "description": "Transfere um ingresso VÁLIDO para outro usuário (por e-mail). Só o detentor atual pode transferir; o código (QR) é regenerado. Defina {{ticketId}} com o id do ingresso."
          },
          "response": []
        }
      ]
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  }
}
