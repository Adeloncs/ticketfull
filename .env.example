# Copie para .env e ajuste os valores. O .env é lido automaticamente pelo Docker Compose
# e NÃO deve ser versionado.

# Segredo de assinatura do JWT (HMAC-SHA). Use no mínimo 32 caracteres.
# Gere um valor forte, por exemplo: openssl rand -base64 48
JWT_SECRET=change-me-to-a-strong-secret-with-at-least-32-chars

# Credenciais do PostgreSQL
POSTGRES_DB=jwt_api
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-postgres-password

# ADMIN inicial criado no startup (opcional). Deixe em branco para não criar nenhum.
ADMIN_EMAIL=admin@ticketfull.com
ADMIN_PASSWORD=change-me-admin-password
