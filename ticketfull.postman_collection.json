{
  "info": {
    "name": "TicketFull API",
    "description": "Coleção completa da API de gerenciamento de eventos e ingressos com autenticação JWT.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8081",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "eventId",
      "value": "",
      "type": "string"
    },
    {
      "key": "ticketBatchId",
      "value": "",
      "type": "string"
    },
    {
      "key": "orderId",
      "value": "",
      "type": "string"
    },
    {
      "key": "codeHash",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Autenticação",
      "item": [
        {
          "name": "Registrar usuário (CUSTOMER)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"cliente@email.com\",\n  \"password\": \"senha123\",\n  \"role\": \"CUSTOMER\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            },
            "description": "Registra um novo usuário com perfil CUSTOMER."
          },
          "response": []
        },
        {
          "name": "Registrar usuário (ORGANIZER)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"organizador@email.com\",\n  \"password\": \"senha123\",\n  \"role\": \"ORGANIZER\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            },
            "description": "Registra um novo usuário com perfil ORGANIZER."
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) {",
                  "    pm.collectionVariables.set('accessToken', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"organizador@email.com\",\n  \"password\": \"senha123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Autentica o usuário e salva o accessToken automaticamente na variável da coleção."
          },
          "response": []
        },
        {
          "name": "Renovar token (Refresh)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) {",
                  "    pm.collectionVariables.set('accessToken', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "refresh"]
            },
            "description": "Renova o access token usando o refreshToken salvo em cookie HttpOnly."
          },
          "response": []
        },
        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.collectionVariables.set('accessToken', '');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "logout"]
            },
            "description": "Encerra a sessão e invalida o refresh token. Limpa o accessToken da coleção."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Eventos",
      "item": [
        {
          "name": "Criar evento",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.id) {",
                  "    pm.collectionVariables.set('eventId', json.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Show de Rock 2026\",\n  \"description\": \"O maior show de rock do ano!\",\n  \"eventDate\": \"2026-12-31T21:00:00Z\",\n  \"location\": \"Estádio Nacional, Brasília\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/events",
              "host": ["{{baseUrl}}"],
              "path": ["events"]
            },
            "description": "Cria um novo evento. Requer perfil ORGANIZER. Salva o eventId automaticamente."
          },
          "response": []
        },
        {
          "name": "Listar eventos",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/events",
              "host": ["{{baseUrl}}"],
              "path": ["events"]
            },
            "description": "Retorna todos os eventos cadastrados."
          },
          "response": []
        },
        {
          "name": "Buscar evento por ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/events/{{eventId}}",
              "host": ["{{baseUrl}}"],
              "path": ["events", "{{eventId}}"]
            },
            "description": "Busca um evento específico pelo seu UUID."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Lotes de Ingressos",
      "item": [
        {
          "name": "Adicionar lote ao evento",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.id) {",
                  "    pm.collectionVariables.set('ticketBatchId', json.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Pista\",\n  \"price\": 120.00,\n  \"totalCapacity\": 500\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/events/{{eventId}}/ticket-batches",
              "host": ["{{baseUrl}}"],
              "path": ["events", "{{eventId}}", "ticket-batches"]
            },
            "description": "Adiciona um lote de ingressos a um evento. Requer perfil ORGANIZER e ser o dono do evento. Salva o ticketBatchId automaticamente."
          },
          "response": []
        },
        {
          "name": "Listar lotes do evento",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/events/{{eventId}}/ticket-batches",
              "host": ["{{baseUrl}}"],
              "path": ["events", "{{eventId}}", "ticket-batches"]
            },
            "description": "Lista todos os lotes de ingressos de um evento."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Pedidos",
      "item": [
        {
          "name": "Comprar ingressos",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.id) {",
                  "    pm.collectionVariables.set('orderId', json.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ticketBatchId\": \"{{ticketBatchId}}\",\n  \"quantity\": 2\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/orders",
              "host": ["{{baseUrl}}"],
              "path": ["orders"]
            },
            "description": "Cria um pedido de compra de ingressos. Requer perfil CUSTOMER. Salva o orderId automaticamente."
          },
          "response": []
        },
        {
          "name": "Listar meus pedidos",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/orders",
              "host": ["{{baseUrl}}"],
              "path": ["orders"]
            },
            "description": "Lista todos os pedidos do cliente autenticado."
          },
          "response": []
        },
        {
          "name": "Buscar pedido por ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/orders/{{orderId}}",
              "host": ["{{baseUrl}}"],
              "path": ["orders", "{{orderId}}"]
            },
            "description": "Busca um pedido específico do cliente autenticado pelo UUID."
          },
          "response": []
        },
        {
          "name": "Confirmar pagamento do pedido",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/orders/{{orderId}}/pay",
              "host": ["{{baseUrl}}"],
              "path": ["orders", "{{orderId}}", "pay"]
            },
            "description": "Confirma o pagamento de um pedido (PENDING → PAID). Requer ser o dono do pedido."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Ingressos",
      "item": [
        {
          "name": "Validar ingresso (check-in)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/tickets/{{codeHash}}/validate",
              "host": ["{{baseUrl}}"],
              "path": ["tickets", "{{codeHash}}", "validate"]
            },
            "description": "Valida um ingresso no check-in do evento (marca como USED). Requer perfil ORGANIZER e ser o dono do evento. Defina a variável {{codeHash}} com o hash do ingresso."
          },
          "response": []
        }
      ]
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  }
}
